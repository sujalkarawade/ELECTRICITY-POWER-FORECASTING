{
  "name": "electricity-power-forecasting",
  "version": "1.0.0",
  "description": "Electricity Power Forecasting Web Application using SARIMA Model",
  "main": "app.py",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python app.py",
    "dev:frontend": "python -m http.server 8080 --directory static & wait-on http://localhost:5000 && start http://localhost:5000",
    "start": "python app.py",
    "install-deps": "pip install -r requirements.txt",
    "setup": "npm run install-deps && npm run dev",
    "build": "echo 'Build completed - ready for deployment'",
    "test": "echo 'Tests not implemented yet'",
    "lint": "echo 'Linting not configured yet'",
    "clean": "echo 'Cleaning temporary files...' && rm -rf uploads/* static/*.png outputs/*.csv models/*.pkl __pycache__ src/__pycache__"
  },
  "keywords": [
    "electricity",
    "forecasting",
    "sarima",
    "time-series",
    "machine-learning",
    "flask",
    "web-app"
  ],
  "author": "Electricity Forecasting Team",
  "license": "MIT",
  "dependencies": {
    "numpy": "^0.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/electricity-power-forecasting.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/electricity-power-forecasting/issues"
  },
  "homepage": "https://github.com/your-username/electricity-power-forecasting#readme",
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.8.0"
  }
}
